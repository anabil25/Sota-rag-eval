{
	"name": "retrieve-ui",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"backend:install": "python -m pip install -e ./retrieve-core[dev]",
		"backend:dev": "python -m uvicorn retrieve.web.app:create_app --factory --host 127.0.0.1 --port 8000",
		"backend:test": "python -m pytest retrieve-core/tests",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:e2e": "playwright install && playwright test",
		"test:live:eval": "node tests/live/sample-eval-generation.mjs",
		"test:coverage": "vitest --run --coverage",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:unit": "vitest"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.62.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"@vitest/coverage-v8": "^4.1.8",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.1.2",
		"vitest": "^4.1.8"
	},
	"overrides": {
		"cookie": "^0.7.2"
	}
}
