# syntax=docker/dockerfile:1

FROM python:3.11-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PORT=8000

RUN groupadd --system retrieve && useradd --system --gid retrieve --create-home retrieve

WORKDIR /app
COPY pyproject.toml ./
COPY src ./src
RUN pip install --no-cache-dir .

WORKDIR /home/retrieve
USER retrieve
EXPOSE 8000
CMD ["python", "-m", "uvicorn", "retrieve.web.app:create_app", "--factory", "--host", "0.0.0.0", "--port", "8000"]
